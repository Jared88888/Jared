# Extend the program so that it validates that the input 
# has exactly the 3 digits using a loop. Ask again if not valid.[2]
########################################################################

# Save your program.
attempts = 0
win = False
for i in range(5):
    if attempts == 5:
        break
    guess = input("Enter your guess: ")
    if not guess.isdigit() or len(guess) != 3:
        while True:
            guess = input("Enter your guess, it has to be 3 digits: ")
            if guess.isdigit() and len(guess) == 3:
                break
    corrects = 0
    attempts += 1
    for i in range(3):
        if secret_code[i] == guess[i]:
            corrects += 1
        if corrects == 3:
            win = True
            print("Correct! ")
            break
    print(f"You have {corrects} digits in the correct position. ")
if win == False:
    print(f"You lost! The answer is {secret_code}. ")